          <mxGeometry height="30" width="200" x="230" y="90" as="geometry" />
        </mxCell>
        <mxCell id="SZqtvzU6itrAq41iEhyQ-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 21px;&quot;&gt;Ticket Booking Application&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="160" x="270" y="130" as="geometry" />
        </mxCell>
        <mxCell id="SZqtvzU6itrAq41iEhyQ-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;u&gt;Functional Requirement&amp;nbsp;&lt;/u&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="150" x="80" y="240" as="geometry" />
        </mxCell>
        <mxCell id="SZqtvzU6itrAq41iEhyQ-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;li data-section-id=&quot;1ouebg&quot; data-start=&quot;149&quot; data-end=&quot;273&quot;&gt;The system must allow users to search and discover events using filters such as event title, location (city), and date.&lt;/li&gt;&lt;li data-section-id=&quot;1xwy2ga&quot; data-start=&quot;275&quot; data-end=&quot;383&quot;&gt;The system must display detailed event information including seat availability (available vs occupied).&lt;/li&gt;&lt;li data-section-id=&quot;szaiz5&quot; data-start=&quot;385&quot; data-end=&quot;499&quot;&gt;The system must provide additional event metadata such as description, cast, duration, language, and ratings.&lt;/li&gt;&lt;li data-section-id=&quot;1tybvj8&quot; data-start=&quot;501&quot; data-end=&quot;581&quot;&gt;The system must allow users to select specific seats from a seating layout.&lt;/li&gt;&lt;li data-section-id=&quot;1wiw2d&quot; data-start=&quot;583&quot; data-end=&quot;691&quot;&gt;The system must enable users to securely complete ticket booking transactions and receive confirmation.&lt;/li&gt;" vertex="1">
          <mxGeometry height="90" width="510" x="90" y="300" as="geometry" />
        </mxCell>
        <mxCell id="SZqtvzU6itrAq41iEhyQ-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;u&gt;Non-Functional Requirement&lt;/u&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="170" x="80" y="430" as="geometry" />
        </mxCell>
        <mxCell id="SZqtvzU6itrAq41iEhyQ-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The system must support scalability to handle up to 100 million daily active users (DAU).&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The system must ensure high availability for search and event viewing, even under heavy traffic.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The system should tolerate slight data staleness (event listings, seat counts) instead of system downtime.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The system must ensure strong consistency during seat booking to prevent double booking.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The system must provide low latency responses for search, viewing, and booking operations.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol data-start=&quot;735&quot; data-end=&quot;1237&quot;&gt;&lt;br&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="140" width="540" x="50" y="460" as="geometry" />
        </mxCell>
        <mxCell id="SZqtvzU6itrAq41iEhyQ-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;u&gt;API Design&lt;/u&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="90" x="80" y="630" as="geometry" />
        </mxCell>
        <mxCell id="SZqtvzU6itrAq41iEhyQ-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;ol data-start=&quot;228&quot; data-end=&quot;1348&quot;&gt;&lt;li data-section-id=&quot;1qeyqs4&quot; data-start=&quot;228&quot; data-end=&quot;439&quot;&gt;&lt;strong data-start=&quot;231&quot; data-end=&quot;254&quot;&gt;Authentication APIs&lt;/strong&gt;&lt;ul data-start=&quot;260&quot; data-end=&quot;439&quot;&gt;&lt;li data-section-id=&quot;1raae2u&quot; data-start=&quot;260&quot; data-end=&quot;312&quot;&gt;&lt;code data-start=&quot;262&quot; data-end=&quot;288&quot;&gt;POST /api/v1/auth/signup&lt;/code&gt; → Register a new user&lt;/li&gt;&lt;li data-section-id=&quot;icbf4g&quot; data-start=&quot;316&quot; data-end=&quot;382&quot;&gt;&lt;code data-start=&quot;318&quot; data-end=&quot;343&quot;&gt;POST /api/v1/auth/login&lt;/code&gt; → Authenticate user and return token&lt;/li&gt;&lt;li data-section-id=&quot;q50f0&quot; data-start=&quot;386&quot; data-end=&quot;439&quot;&gt;&lt;code data-start=&quot;388&quot; data-end=&quot;410&quot;&gt;GET /api/v1/users/me&lt;/code&gt; → Get current user profile&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li data-section-id=&quot;6orzlo&quot; data-start=&quot;441&quot; data-end=&quot;697&quot;&gt;&lt;strong data-start=&quot;444&quot; data-end=&quot;469&quot;&gt;Event Management APIs&lt;/strong&gt;&lt;ul data-start=&quot;475&quot; data-end=&quot;697&quot;&gt;&lt;li data-section-id=&quot;lipjyu&quot; data-start=&quot;475&quot; data-end=&quot;529&quot;&gt;&lt;code data-start=&quot;477&quot; data-end=&quot;498&quot;&gt;POST /api/v1/events&lt;/code&gt; → Create a new event (admin)&lt;/li&gt;&lt;li data-section-id=&quot;18yb8zw&quot; data-start=&quot;533&quot; data-end=&quot;588&quot;&gt;&lt;code data-start=&quot;535&quot; data-end=&quot;566&quot;&gt;GET /api/v1/events/{event_id}&lt;/code&gt; → Get event details&lt;/li&gt;&lt;li data-section-id=&quot;1saepxg&quot; data-start=&quot;592&quot; data-end=&quot;697&quot;&gt;&lt;code data-start=&quot;594&quot; data-end=&quot;672&quot;&gt;GET /api/v1/events?location={location}&amp;amp;date={date}&amp;amp;page={page}&amp;amp;limit={limit}&lt;/code&gt; → Search/filter events&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1vust86&quot; data-start=&quot;699&quot; data-end=&quot;933&quot;&gt;&lt;strong data-start=&quot;702&quot; data-end=&quot;726&quot;&gt;Seat Management APIs&lt;/strong&gt;&lt;ul data-start=&quot;732&quot; data-end=&quot;933&quot;&gt;&lt;li data-section-id=&quot;3mhiji&quot; data-start=&quot;732&quot; data-end=&quot;808&quot;&gt;&lt;code data-start=&quot;734&quot; data-end=&quot;771&quot;&gt;GET /api/v1/events/{event_id}/seats&lt;/code&gt; → Get seat layout and availability&lt;/li&gt;&lt;li data-section-id=&quot;wz0hm2&quot; data-start=&quot;812&quot; data-end=&quot;875&quot;&gt;&lt;code data-start=&quot;814&quot; data-end=&quot;839&quot;&gt;POST /api/v1/seats/lock&lt;/code&gt; → Temporarily lock selected seats&lt;/li&gt;&lt;li data-section-id=&quot;1rsphke&quot; data-start=&quot;879&quot; data-end=&quot;933&quot;&gt;&lt;code data-start=&quot;881&quot; data-end=&quot;908&quot;&gt;POST /api/v1/seats/unlock&lt;/code&gt; → Release locked seats&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li data-section-id=&quot;ujrirw&quot; data-start=&quot;935&quot; data-end=&quot;1201&quot;&gt;&lt;strong data-start=&quot;938&quot; data-end=&quot;954&quot;&gt;Booking APIs&lt;/strong&gt;&lt;ul data-start=&quot;960&quot; data-end=&quot;1201&quot;&gt;&lt;li data-section-id=&quot;1ib7hy6&quot; data-start=&quot;960&quot; data-end=&quot;1029&quot;&gt;&lt;code data-start=&quot;962&quot; data-end=&quot;985&quot;&gt;POST /api/v1/bookings&lt;/code&gt; → Create a booking (initiate reservation)&lt;/li&gt;&lt;li data-section-id=&quot;1lqjn2a&quot; data-start=&quot;1033&quot; data-end=&quot;1113&quot;&gt;&lt;code data-start=&quot;1035&quot; data-end=&quot;1079&quot;&gt;POST /api/v1/bookings/{booking_id}/confirm&lt;/code&gt; → Confirm booking after payment&lt;/li&gt;&lt;li data-section-id=&quot;1n8n8ci&quot; data-start=&quot;1117&quot; data-end=&quot;1201&quot;&gt;&lt;code data-start=&quot;1119&quot; data-end=&quot;1170&quot;&gt;GET /api/v1/bookings/my?page={page}&amp;amp;limit={limit}&lt;/code&gt; → Get user’s booking history&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1bldc0o&quot; data-start=&quot;1203&quot; data-end=&quot;1348&quot;&gt;&lt;strong data-start=&quot;1206&quot; data-end=&quot;1222&quot;&gt;Payment APIs&lt;/strong&gt;&lt;ul data-start=&quot;1228&quot; data-end=&quot;1348&quot;&gt;&lt;li data-section-id=&quot;1mmx1fm&quot; data-start=&quot;1228&quot; data-end=&quot;1274&quot;&gt;&lt;code data-start=&quot;1230&quot; data-end=&quot;1253&quot;&gt;POST /api/v1/payments&lt;/code&gt; → Initiate payment&lt;/li&gt;&lt;li data-section-id=&quot;1872tlh&quot; data-start=&quot;1278&quot; data-end=&quot;1348&quot;&gt;&lt;code data-start=&quot;1280&quot; data-end=&quot;1311&quot;&gt;POST /api/v1/payments/webhook&lt;/code&gt; → Handle payment gateway callbacks&amp;nbsp;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="320" width="810" x="60" y="670" as="geometry" />
        </mxCell>
